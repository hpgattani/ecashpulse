{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "ecash-pulse-mcp",
      "version": "0.1.0",
      "title": "eCash Pulse MCP"
    },
    "tools": [
      {
        "name": "list_predictions",
        "title": "List predictions",
        "description": "List prediction markets on eCash Pulse. Filter by status (active, resolved, awaiting_resolution) and category. Returns title, pools, dates, and status.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "active",
                "resolved",
                "awaiting_resolution",
                "cancelled"
              ],
              "description": "Filter by market status. Omit for all statuses."
            },
            "category": {
              "type": "string",
              "description": "Filter by category (e.g. sports, crypto, politics)."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 20
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_prediction",
        "title": "Get prediction",
        "description": "Fetch a single prediction market by ID, including pools, status, and dates.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Prediction market UUID."
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_leaderboard",
        "title": "Get leaderboard",
        "description": "Fetch the eCash Pulse leaderboard: top users ranked by wins, winnings, and win rate.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_platform_stats",
        "title": "Get platform stats",
        "description": "Fetch aggregate eCash Pulse platform statistics: total volume, users, markets, and bets.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_raffles",
        "title": "List raffles",
        "description": "List active and past raffles on eCash Pulse, including ticket price and prize pool.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 20
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_top_volume_markets",
        "title": "Get top volume markets",
        "description": "Fetch the highest-volume prediction markets on eCash Pulse.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 10
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
